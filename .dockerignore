# Files NOT shipped to the HF Space training image.
# Everything else IS shipped (freshprice_env, training, eval, server,
# scripts/, requirements*.txt, pyproject.toml).

# Secrets — set HF_TOKEN as a Space Secret in the UI, never via file.
.env
.env.local
.env.*.local

# Git + IDE
.git/
.gitattributes
.gitignore
.vscode/
.idea/
*.DS_Store

# Python build artefacts
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.venv/
venv/

# Notebooks (Space runs scripts/train_full_pipeline.py, not Jupyter)
*.ipynb
**/*.ipynb_checkpoints/

# Heavy / generated artefacts (regenerated by the pipeline)
checkpoints/
plots/
wandb/
training/sft_data/*.json
data/comparison_results.json
eval/baseline_results.json
eval/plots/
training_log.jsonl
episode_log.jsonl

# Hackathon docs + drafts (not used at training time)
README.md
RUN.md
VSCODE_HF.md
CLAUDE.md
DEVELOPER_GUIDE.md
FreshPrice_SDD.md
HACKATHON_CLAUDE_PROMPT.md
*.pdf
*.docx

# Tests (optional — uncomment if you want them included)
tests/

# Static dashboard (we serve the dashboard locally, not from the Space)
static/

# Legacy / OpenEnv-specific files (not loaded by train_full_pipeline.py)
app.py
client.py
models.py
inference.py
validate_submission.py
openenv.yaml

# The serving Dockerfile is the wrong Dockerfile for training.
Dockerfile
