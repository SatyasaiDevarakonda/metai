# ---------------------------------------------------------------------------
# QStorePrice -- environment variables
# Copy this file to `.env` and fill in your values. `.env` is gitignored.
# Read by both server/agent_runtime.py at start-up and the training scripts.
# ---------------------------------------------------------------------------

# ===========================================================================
# Hugging Face (single source of truth for HF auth)
# ===========================================================================
# Token with READ + WRITE scope. Read scope alone is enough to PULL Qwen-2.5-7B
# (gated). Write is only needed if you push checkpoints to your own repo.
HF_TOKEN=hf_your_token_here

# Where to push trained checkpoints + where to pull them back from. Format:
# <hf-username>/<repo-name>. Repo is created on first push.
HF_REPO_ID=your-hf-username/qstoreprice-sft

# ===========================================================================
# Agent runtime (server/agent_runtime.py at dashboard start-up)
# ===========================================================================
# Pick ONE backend:
#   scripted     -- no model, heuristic stand-in (default if nothing else set)
#   hf_inference -- calls the HF Inference router; no local GPU, uses HF credit
#   local        -- loads the merged checkpoint from MODEL_PATH (needs ~14 GB GPU)
AGENT_BACKEND=hf_inference

# For AGENT_BACKEND=local (needs a local GPU + transformers+peft installed):
MODEL_PATH=

# ===========================================================================
# Comparison rig (inference_comparison.py + dashboard "Before vs After RL")
# ===========================================================================
# Either may be set; both are optional. The dashboard rig falls back to
# HF_REPO_ID/HF_TOKEN for the "rl" slot when RL_MODEL_PATH is empty.
SFT_MODEL_PATH=
RL_MODEL_PATH=

# ===========================================================================
# Live training -> dashboard bridge
# ===========================================================================
# When set, training/reinforce_trainer.py + ppo_trainer.py POST per-step
# stats to <DASHBOARD_URL>/training/event so the Live RL Telemetry panel
# updates in real time. Use ngrok / Cloudflare Tunnel if dashboard is local
# but training runs on a remote GPU.
DASHBOARD_URL=

# ===========================================================================
# External LLM-judge graders (optional sub-prizes)
# ===========================================================================
EXTERNAL_GRADER=local            # one of: local | patronus | halluminate
PATRONUS_API_KEY=
HALLUMINATE_API_KEY=

# ===========================================================================
# Misc
# ===========================================================================
WANDB_PROJECT=                   # set to enable W&B logging from SFT
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
WORKERS=1
