# ---------------------------------------------------------------------------
# QStorePrice -- environment variables
# Copy this file to `.env` and fill in your values. Most of these are read by
# the FastAPI server (server/app.py + server/agent_runtime.py) at start-up.
# ---------------------------------------------------------------------------

# ---- Inference (judges' inference.py + agent runtime) ---------------------
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini
HF_TOKEN=hf_your_token_here

# ---- Agent runtime (server/agent_runtime.py) ------------------------------
# Pick ONE of:
#   AGENT_BACKEND=scripted        # default if nothing else is set; no model
#   AGENT_BACKEND=hf_inference    # uses HF_REPO_ID + HF_TOKEN below
#   AGENT_BACKEND=local           # uses MODEL_PATH below
AGENT_BACKEND=scripted

# For AGENT_BACKEND=hf_inference (no GPU required, needs HF credits):
HF_REPO_ID=your-hf-username/qstoreprice-sft

# For AGENT_BACKEND=local (needs an 8 GB+ GPU, transformers+peft installed):
MODEL_PATH=/abs/path/to/checkpoints/final
